# ── OpenAI API 키 설정 ─────────────────────────────────────────
# 1) 이 파일을 복사해 `secrets.toml` 로 저장하세요 (이름 정확히).
# 2) 아래 따옴표 안에 본인 키를 붙여넣으세요.
# 3) `secrets.toml`은 절대 Git에 커밋하지 마세요 (.gitignore 처리됨).
#
# PowerShell (프로젝트 루트에서):
#   Copy-Item .streamlit\secrets.toml.example .streamlit\secrets.toml
# 그 다음 `.streamlit\secrets.toml` 을 메모장으로 열어 키를 넣으세요.
#
# 또는 환경 변수만 쓰려면 (세션마다):
#   $env:OPENAI_API_KEY="sk-..."
#   streamlit run app.py

OPENAI_API_KEY = "sk-여기에_본인_API_키를_붙여넣기"
